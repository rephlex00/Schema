{
  "name": "obsidian-schema",
  "version": "1.0.0",
  "description": "Typed-note workflow for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "node esbuild.config.mjs production && cp main.js manifest.json styles.css \"/Users/jamesdurkee/Documents/Obsidian/Personal New/.obsidian/plugins/schema/\" 2>/dev/null || true"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
